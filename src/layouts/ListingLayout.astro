---
import BaseLayout from './BaseLayout.astro';
import CategoryTabs from '../components/sections/CategoryTabs.astro';
import type { Locale } from '../i18n/config';
import { getFeedTabs } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  path: string;
  activeTab: string;
  locale: Locale;
}

const { title, description, path, activeTab, locale } = Astro.props;
const feedTabs = getFeedTabs(locale);
---

<BaseLayout title={title} description={description} path={path}>
  <section class="container-site py-12">
    <h1 class="font-sans text-3xl font-bold sm:text-4xl">{title}</h1>
    <p class="mt-3 max-w-2xl text-[var(--color-text-dim)]">{description}</p>
  </section>
  <CategoryTabs tabs={feedTabs} activeHref={activeTab} />
  <slot />
</BaseLayout>
