---
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import TagList from '../components/ui/TagList.astro';
import KeyTakeaways from '../components/article/KeyTakeaways.astro';
import SourceList from '../components/article/SourceList.astro';
import RelatedArticles from '../components/article/RelatedArticles.astro';
import ArticleAiBadge from '../components/article/ArticleAiBadge.astro';
import NewsletterSignup from '../components/forms/NewsletterSignup.astro';
import { formatDateTime } from '../utils/formatDate';
import type { ArticleEntry } from '../utils/content';
import { getCategoryHref, getCategoryLabel } from '../utils/content';
import { articlePageJsonLd, DEFAULT_OG_IMAGE } from '../utils/seo';
import { formatDateTimeISO } from '../utils/formatDate';
import { getRelatedArticles } from '../utils/tags';
import { t } from '../i18n/ui';

interface Props {
  article: ArticleEntry;
  allArticles: ArticleEntry[];
}

const { article, allArticles } = Astro.props;
const relatedArticles = getRelatedArticles(article, allArticles, 3);
const { data } = article;
const locale = article.locale;
const categoryLabel = getCategoryLabel(article);
const categoryHref = getCategoryHref(article);
---

<BaseLayout
  title={data.title}
  description={data.description}
  path={Astro.url.pathname}
  ogType="article"
  ogImage={data.heroImage ?? DEFAULT_OG_IMAGE}
  publishedTime={formatDateTimeISO(data.date)}
  modifiedTime={formatDateTimeISO(data.updated ?? data.date)}
  articleTags={data.tags}
  jsonLd={articlePageJsonLd(article)}
>
  <article class="container-site py-10 lg:py-14">
    <header class="max-w-3xl">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <CategoryBadge label={categoryLabel} href={categoryHref} />
        {data.status === 'draft' && <span class="badge text-amber-400">{t(locale, 'draftBadge')}</span>}
      </div>
      <ArticleAiBadge
        locale={locale}
        aiAssistance={data.aiAssistance}
        commercialDisclosure={data.commercialDisclosure}
      />
      <h1 class="font-sans text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
        {data.title}
      </h1>
      <p class="mt-4 text-xl text-[var(--color-text-dim)]">{data.description}</p>
      <div class="mt-6 flex flex-wrap gap-4 border-y border-[var(--color-border)] py-4 text-sm text-[var(--color-text-muted)]">
        <time datetime={data.date.toISOString()}>{formatDateTime(data.date, locale)}</time>
        <span>{data.author}</span>
        {data.readingTime && <span>{data.readingTime}</span>}
      </div>
      {data.tags.length > 0 && (
        <div class="mt-4">
          <TagList tags={data.tags} />
        </div>
      )}
    </header>

    {data.heroImage && (
      <figure class="my-10 overflow-hidden rounded-xl border border-[var(--color-border)]">
        <img
          src={data.heroImage}
          alt={data.heroAlt ?? data.title}
          class="aspect-video w-full object-contain bg-[var(--color-bg-soft)]"
          width="1600"
          height="900"
        />
        {data.heroCaption && (
          <figcaption class="px-4 py-2 text-xs text-[var(--color-text-muted)]">
            {data.heroCaption}
          </figcaption>
        )}
      </figure>
    )}

    {data.keyClaims.length > 0 && (
      <KeyTakeaways items={data.keyClaims} title={t(locale, 'keyClaimsTitle')} />
    )}

    <div class="prose-faktum mx-auto max-w-3xl">
      <slot />
    </div>

    <SourceList sources={data.sources} locale={locale} />

    {data.needsFactCheck && (
      <p class="mx-auto mt-8 max-w-3xl text-xs text-[var(--color-text-muted)]">
        {t(locale, 'factCheckNote')}
      </p>
    )}

    <NewsletterSignup locale={locale} variant="articleEnd" sourceUrl={Astro.url.pathname} />
  </article>

  <div class="container-site pb-16">
    <RelatedArticles articles={relatedArticles} currentId={article.id} />
  </div>
</BaseLayout>
