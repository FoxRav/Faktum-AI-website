---
import BaseLayout from './BaseLayout.astro';
import LegalProse from '../components/legal/LegalProse.astro';

interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
---

<BaseLayout title={title} description={description} path={path}>
  <LegalProse title={title} description={description} path={path}>
    <slot />
  </LegalProse>
</BaseLayout>
