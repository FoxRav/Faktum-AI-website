---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getLocaleFromPath, translatePath } from '../i18n/paths';
import { htmlLang } from '../i18n/config';
import { canonicalUrl, DEFAULT_OG_IMAGE, absoluteAssetUrl } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogType = 'website',
  ogImage,
  publishedTime,
  modifiedTime,
  articleTags = [],
  jsonLd,
} = Astro.props;

const locale = getLocaleFromPath(path);
const fullTitle = title.includes('Faktum AI') ? title : `${title} · Faktum AI`;
const canonical = canonicalUrl(path);
const alternateFi = canonicalUrl(translatePath(path, 'fi'));
const alternateEn = canonicalUrl(translatePath(path, 'en'));
const site = Astro.site ?? 'https://www.faktum-ai.com';
const ogLocale = locale === 'fi' ? 'fi_FI' : 'en_US';
const ogImageUrl = absoluteAssetUrl(ogImage ?? DEFAULT_OG_IMAGE, String(site));
const jsonLdItems = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fi" href={alternateFi} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="x-default" href={alternateFi} />
    <meta property="og:site_name" content="Faktum AI" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={title} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === 'article' &&
      articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="Faktum AI RSS" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    {jsonLdItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
