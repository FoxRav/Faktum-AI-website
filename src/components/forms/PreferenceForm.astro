---
import type { Locale } from '../../i18n/config';
import {
  INTEREST_LABELS,
  ROLE_LABELS,
  SUBSCRIBER_INTERESTS,
  SUBSCRIBER_ROLES,
} from '../../i18n/subscriber';
import { subscribePath } from '../../i18n/paths';
import { t } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section
  class="preference-form container-site max-w-2xl py-12"
  data-locale={locale}
  data-msg-invalid={t(locale, 'subscribeInvalidToken')}
  data-msg-saved={t(locale, 'preferencesSaved')}
  data-msg-saving={t(locale, 'preferencesSaving')}
  data-msg-save-failed={t(locale, 'preferencesSaveFailed')}
  data-label-save={t(locale, 'preferencesSave')}
>
  <h1 class="font-sans text-3xl font-bold">{t(locale, 'preferencesTitle')}</h1>

  <div class="preference-missing mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
    <p class="text-[var(--color-text)]">{t(locale, 'preferencesMissingToken')}</p>
    <p class="mt-3 text-sm text-[var(--color-text-dim)]">
      {t(locale, 'preferencesMissingTokenHelp')}
    </p>
    <a href={subscribePath(locale)} class="btn-primary mt-5 inline-flex">
      {t(locale, 'footerSubscribe')}
    </a>
  </div>

  <div class="preference-content hidden">
    <p class="preference-email mt-4 text-sm text-[var(--color-text-dim)]"></p>
    <p class="preference-status mt-2 hidden text-sm font-medium" aria-live="polite"></p>

    <form class="preference-save-form mt-8 space-y-6">
      <div>
        <label class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          {t(locale, 'preferencesPrimaryRole')}
        </label>
        <select
          name="primaryRole"
          class="mt-2 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-4 py-2.5"
        >
          <option value="">—</option>
          {SUBSCRIBER_ROLES.map((role) => (
            <option value={role}>{ROLE_LABELS[locale][role]}</option>
          ))}
        </select>
      </div>

      <fieldset>
        <legend class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          {t(locale, 'preferencesSecondaryRoles')}
        </legend>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          {SUBSCRIBER_ROLES.map((role) => (
            <label class="flex items-center gap-2 text-sm text-[var(--color-text-dim)]">
              <input type="checkbox" name="secondaryRoles" value={role} class="rounded" />
              {ROLE_LABELS[locale][role]}
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          {t(locale, 'preferencesInterests')}
        </legend>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          {SUBSCRIBER_INTERESTS.map((interest) => (
            <label class="flex items-center gap-2 text-sm text-[var(--color-text-dim)]">
              <input type="checkbox" name="interests" value={interest} class="rounded" />
              {INTEREST_LABELS[locale][interest]}
            </label>
          ))}
        </div>
      </fieldset>

      <div>
        <label class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          {t(locale, 'subscribeLanguageLabel')}
        </label>
        <select
          name="preferredLanguage"
          class="mt-2 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-4 py-2.5"
        >
          <option value="fi">{t(locale, 'subscribeLanguageFi')}</option>
          <option value="en">{t(locale, 'subscribeLanguageEn')}</option>
          <option value="both">{t(locale, 'subscribeLanguageBoth')}</option>
        </select>
      </div>

      <button
        type="submit"
        class="preference-save-btn rounded-lg bg-cyan-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-cyan-400 disabled:cursor-not-allowed disabled:opacity-60"
      >
        {t(locale, 'preferencesSave')}
      </button>
    </form>
  </div>
</section>

<script is:inline>
  (async function () {
    var root = document.querySelector('.preference-form');
    if (!root) return;

    var token = new URLSearchParams(window.location.search).get('token') || '';
    var missingEl = root.querySelector('.preference-missing');
    var contentEl = root.querySelector('.preference-content');
    var form = root.querySelector('.preference-save-form');
    var emailEl = root.querySelector('.preference-email');
    var statusEl = root.querySelector('.preference-status');
    var saveBtn = root.querySelector('.preference-save-btn');
    var invalidMsg = root.getAttribute('data-msg-invalid') || '';
    var savedMsg = root.getAttribute('data-msg-saved') || '';
    var savingMsg = root.getAttribute('data-msg-saving') || '';
    var saveFailedMsg = root.getAttribute('data-msg-save-failed') || '';
    var saveLabel = root.getAttribute('data-label-save') || 'Tallenna';

    if (!token || !form || !contentEl) return;

    if (missingEl) missingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    function showStatus(text, kind) {
      if (!statusEl) return;
      statusEl.textContent = text;
      statusEl.classList.remove('hidden', 'text-cyan-400', 'text-red-400', 'text-[var(--color-text-muted)]');
      if (kind === 'success') statusEl.classList.add('text-cyan-400');
      else if (kind === 'error') statusEl.classList.add('text-red-400');
      else statusEl.classList.add('text-[var(--color-text-muted)]');
    }

    try {
      var loadRes = await fetch('/api/preferences?token=' + encodeURIComponent(token));
      var loadData = await loadRes.json();
      if (!loadRes.ok || !loadData.preferences) throw new Error('load_failed');

      var prefs = loadData.preferences;
      if (emailEl) emailEl.textContent = prefs.email;

      var primary = form.querySelector('select[name="primaryRole"]');
      if (primary && 'value' in primary) primary.value = prefs.primaryRole || '';

      var lang = form.querySelector('select[name="preferredLanguage"]');
      if (lang && 'value' in lang) lang.value = prefs.preferredLanguage || 'fi';

      form.querySelectorAll('input[name="secondaryRoles"]').forEach(function (input) {
        if ('checked' in input && 'value' in input) {
          input.checked = (prefs.secondaryRoles || []).indexOf(input.value) >= 0;
        }
      });

      form.querySelectorAll('input[name="interests"]').forEach(function (input) {
        if ('checked' in input && 'value' in input) {
          input.checked = (prefs.interests || []).indexOf(input.value) >= 0;
        }
      });
    } catch (e) {
      if (contentEl) contentEl.classList.add('hidden');
      if (missingEl) {
        missingEl.classList.remove('hidden');
        var help = missingEl.querySelector('p.text-sm');
        if (help) help.textContent = invalidMsg;
      }
      return;
    }

    form.addEventListener('submit', async function (event) {
      event.preventDefault();
      if (form.getAttribute('data-submitting') === 'true') return;
      form.setAttribute('data-submitting', 'true');

      var secondaryRoles = [];
      form.querySelectorAll('input[name="secondaryRoles"]:checked').forEach(function (input) {
        if ('value' in input) secondaryRoles.push(input.value);
      });
      var interests = [];
      form.querySelectorAll('input[name="interests"]:checked').forEach(function (input) {
        if ('value' in input) interests.push(input.value);
      });
      var primaryRoleEl = form.querySelector('select[name="primaryRole"]');
      var preferredLanguageEl = form.querySelector('select[name="preferredLanguage"]');

      if (saveBtn && 'disabled' in saveBtn) {
        saveBtn.disabled = true;
        saveBtn.textContent = savingMsg;
      }
      showStatus(savingMsg, 'pending');

      try {
        var saveRes = await fetch('/api/preferences', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            token: token,
            primaryRole: primaryRoleEl && 'value' in primaryRoleEl ? primaryRoleEl.value || null : null,
            secondaryRoles: secondaryRoles,
            interests: interests,
            preferredLanguage:
              preferredLanguageEl && 'value' in preferredLanguageEl ? preferredLanguageEl.value : 'fi',
          }),
        });
        var saveData = await saveRes.json();
        if (!saveRes.ok || !saveData.ok) throw new Error('save_failed');
        showStatus(savedMsg, 'success');
        saveBtn && saveBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } catch (err) {
        showStatus(saveFailedMsg, 'error');
      } finally {
        form.removeAttribute('data-submitting');
        if (saveBtn && 'disabled' in saveBtn) {
          saveBtn.disabled = false;
          saveBtn.textContent = saveLabel;
        }
      }
    });
  })();
</script>
