---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const unsubscribedPath = locale === 'en' ? '/en/subscribe/unsubscribed/' : '/tilaa/peruutettu/';
---

<section
  class="unsubscribe-form container-site max-w-lg py-16"
  data-locale={locale}
  data-unsubscribed-path={unsubscribedPath}
  data-msg-invalid={t(locale, 'subscribeInvalidToken')}
  data-msg-failed={t(locale, 'unsubscribeFailed')}
  data-msg-request-success={t(locale, 'unsubscribeRequestSuccess')}
  data-msg-request-email={t(locale, 'unsubscribeRequestEmailFailed')}
  data-msg-request-failed={t(locale, 'unsubscribeRequestFailed')}
  data-msg-email-send={t(locale, 'subscribeEmailSendFailed')}
>
  <h1 class="font-sans text-3xl font-bold">{t(locale, 'unsubscribeTitle')}</h1>
  <p class="unsubscribe-lead mt-4 text-[var(--color-text-dim)]">{t(locale, 'unsubscribeLead')}</p>

  <div class="unsubscribe-missing mt-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
    <p class="text-[var(--color-text)]">{t(locale, 'unsubscribeMissingToken')}</p>
    <p class="mt-3 text-sm text-[var(--color-text-dim)]">
      {t(locale, 'unsubscribeMissingTokenHelp')}
    </p>

    <form class="unsubscribe-request-form mt-6 space-y-4">
      <div class="absolute -left-[9999px]" aria-hidden="true">
        <label>
          Leave empty
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </label>
      </div>
      <div>
        <label
          class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]"
          for="unsubscribe-email"
        >
          {t(locale, 'unsubscribeRequestEmailLabel')}
        </label>
        <input
          type="email"
          name="email"
          id="unsubscribe-email"
          required
          autocomplete="email"
          class="mt-2 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2.5 text-[var(--color-text)]"
        />
      </div>
      <p class="unsubscribe-request-msg hidden text-sm" aria-live="polite"></p>
      <button
        type="submit"
        class="rounded-lg bg-cyan-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400"
      >
        {t(locale, 'unsubscribeRequestSubmit')}
      </button>
    </form>
  </div>

  <div class="unsubscribe-with-token mt-8 hidden">
    <p class="text-[var(--color-text-dim)]">{t(locale, 'unsubscribeLeadWithToken')}</p>
    <button
      type="button"
      class="unsubscribe-btn mt-4 rounded-lg border border-red-500/40 px-5 py-2.5 text-sm font-semibold text-red-300 hover:bg-red-500/10"
    >
      {t(locale, 'unsubscribeConfirm')}
    </button>
    <p class="unsubscribe-msg mt-4 text-sm" aria-live="polite"></p>
  </div>

  <p class="unsubscribe-invalid mt-8 hidden text-sm text-red-400" role="alert"></p>
</section>

<script is:inline>
  (function () {
    var root = document.querySelector('.unsubscribe-form');
    if (!root) return;

    var token = new URLSearchParams(window.location.search).get('token') || '';
    var missingEl = root.querySelector('.unsubscribe-missing');
    var withTokenEl = root.querySelector('.unsubscribe-with-token');
    var invalidEl = root.querySelector('.unsubscribe-invalid');
    var leadEl = root.querySelector('.unsubscribe-lead');
    var btn = root.querySelector('.unsubscribe-btn');
    var msgEl = root.querySelector('.unsubscribe-msg');
    var requestForm = root.querySelector('.unsubscribe-request-form');
    var requestMsgEl = root.querySelector('.unsubscribe-request-msg');
    var unsubscribedPath = root.getAttribute('data-unsubscribed-path') || '/tilaa/peruutettu/';
    var invalidMsg = root.getAttribute('data-msg-invalid') || '';
    var failedMsg = root.getAttribute('data-msg-failed') || '';
    var locale = root.getAttribute('data-locale') || 'fi';

    if (token) {
      if (leadEl) leadEl.classList.add('hidden');
      if (missingEl) missingEl.classList.add('hidden');
      if (withTokenEl) withTokenEl.classList.remove('hidden');
    }

    if (requestForm) {
      requestForm.addEventListener('submit', async function (event) {
        event.preventDefault();
        var submitBtn = requestForm.querySelector('button[type="submit"]');
        var emailInput = requestForm.querySelector('input[name="email"]');
        var honeypot = requestForm.querySelector('input[name="website"]');
        var email = emailInput && 'value' in emailInput ? String(emailInput.value).trim() : '';

        function showRequestMessage(text, isError) {
          if (!requestMsgEl) return;
          requestMsgEl.textContent = text;
          requestMsgEl.classList.remove('hidden', 'text-cyan-400', 'text-red-400');
          requestMsgEl.classList.add(isError ? 'text-red-400' : 'text-cyan-400');
        }

        if (!email || email.indexOf('@') < 1) {
          showRequestMessage(root.getAttribute('data-msg-request-email') || '', true);
          return;
        }

        if (submitBtn && 'disabled' in submitBtn) submitBtn.disabled = true;

        try {
          var response = await fetch('/api/unsubscribe-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: email,
              locale: locale,
              honeypot: honeypot && 'value' in honeypot ? honeypot.value : '',
            }),
          });
          var data = await response.json();
          if (!response.ok) {
            var code = data && data.error ? data.error : 'generic';
            if (code === 'invalid_email') {
              showRequestMessage(root.getAttribute('data-msg-request-email') || '', true);
            } else if (code === 'email_send_failed') {
              showRequestMessage(root.getAttribute('data-msg-email-send') || '', true);
            } else {
              showRequestMessage(root.getAttribute('data-msg-request-failed') || '', true);
            }
            return;
          }
          showRequestMessage(root.getAttribute('data-msg-request-success') || '', false);
          requestForm.reset();
        } catch (e) {
          showRequestMessage(root.getAttribute('data-msg-request-failed') || '', true);
        } finally {
          if (submitBtn && 'disabled' in submitBtn) submitBtn.disabled = false;
        }
      });
    }

    if (!token || !btn) return;

    btn.addEventListener('click', async function () {
      if (msgEl) {
        msgEl.textContent = '';
        msgEl.classList.remove('text-red-400');
      }
      if ('disabled' in btn) btn.disabled = true;

      try {
        var response = await fetch('/api/unsubscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: token }),
        });
        var data = await response.json();
        if (!response.ok || !data.ok) throw new Error('unsubscribe_failed');
        window.location.href = unsubscribedPath;
      } catch (e) {
        if (withTokenEl) withTokenEl.classList.add('hidden');
        if (invalidEl) {
          invalidEl.textContent = invalidMsg || failedMsg;
          invalidEl.classList.remove('hidden');
        } else if (msgEl) {
          msgEl.textContent = failedMsg;
          msgEl.classList.add('text-red-400');
        }
        if ('disabled' in btn) btn.disabled = false;
      }
    });
  })();
</script>
