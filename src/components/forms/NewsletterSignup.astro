---
import type { Locale } from '../../i18n/config';
import { subscribePath, privacyPath } from '../../i18n/paths';
import { t } from '../../i18n/ui';
import ConsentCheckbox from './ConsentCheckbox.astro';

interface Props {
  locale: Locale;
  variant?: 'compact' | 'full' | 'articleEnd';
  sourceUrl?: string;
}

const { locale, variant = 'compact', sourceUrl = Astro.url.pathname } = Astro.props;
const isCompact = variant === 'compact' || variant === 'articleEnd';
const formId = `newsletter-${variant}-${locale}`;
---

<section
  class:list={[
    'newsletter-signup rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)]',
    isCompact ? 'p-6' : 'p-8 lg:p-10',
    variant === 'articleEnd' ? 'mx-auto mt-12 max-w-3xl' : '',
  ]}
  data-locale={locale}
  data-form-id={formId}
>
  <h2
    class:list={[
      'font-sans font-bold text-[var(--color-text)]',
      variant === 'articleEnd' ? 'text-xl' : 'text-2xl',
    ]}
  >
    {t(locale, 'subscribeTitle')}
  </h2>
  <p class="mt-3 text-sm text-[var(--color-text-dim)]">
    {variant === 'articleEnd' ? t(locale, 'subscribeArticleCta') : t(locale, 'subscribeLead')}
  </p>

  <form class="newsletter-form mt-6 space-y-4" data-source-url={sourceUrl}>
    <div class="absolute -left-[9999px]" aria-hidden="true">
      <label>
        Leave empty
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <div>
      <label class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]" for={`${formId}-email`}>
        {t(locale, 'subscribeEmailLabel')}
      </label>
      <input
        type="email"
        name="email"
        id={`${formId}-email`}
        required
        autocomplete="email"
        class="mt-2 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2.5 text-[var(--color-text)]"
      />
    </div>

    <div>
      <label class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]" for={`${formId}-lang`}>
        {t(locale, 'subscribeLanguageLabel')}
      </label>
      <select
        name="preferredLanguage"
        id={`${formId}-lang`}
        class="mt-2 w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2.5 text-[var(--color-text)]"
      >
        <option value="fi">{t(locale, 'subscribeLanguageFi')}</option>
        <option value="en">{t(locale, 'subscribeLanguageEn')}</option>
        <option value="both">{t(locale, 'subscribeLanguageBoth')}</option>
      </select>
    </div>

    <ConsentCheckbox locale={locale} id={`${formId}-consent`} />

    <p class="newsletter-message hidden text-sm" aria-live="polite"></p>

    <button
      type="submit"
      class="rounded-lg bg-cyan-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400"
    >
      {t(locale, 'subscribeSubmit')}
    </button>
  </form>

  {!isCompact && (
    <p class="mt-4 text-xs text-[var(--color-text-muted)]">
      <a href={subscribePath(locale)} class="text-cyan-400 hover:underline">
        {t(locale, 'footerSubscribe')}
      </a>
      ·
      <a href={privacyPath(locale)} class="text-cyan-400 hover:underline">
        {t(locale, 'footerPrivacy')}
      </a>
    </p>
  )}
</section>

<script is:inline>
  document.querySelectorAll('.newsletter-form').forEach(function (form) {
    form.addEventListener('submit', async function (event) {
      event.preventDefault();
      var section = form.closest('.newsletter-signup');
      if (!section) return;

      var locale = section.getAttribute('data-locale') || 'fi';
      var messageEl = section.querySelector('.newsletter-message');
      var submitBtn = form.querySelector('button[type="submit"]');

      var messages = {
        fi: {
          success: 'Tarkista sähköpostisi ja vahvista tilaus.',
          generic: 'Tilaus epäonnistui. Yritä uudelleen.',
          emailSend: 'Sähköpostin lähetys epäonnistui. Yritä hetken päästä uudelleen.',
          email: 'Anna kelvollinen sähköpostiosoite.',
          consent: 'Uutiskirjeen tilaus vaatii suostumuksen.',
        },
        en: {
          success: 'Check your email and confirm your subscription.',
          generic: 'Subscription failed. Please try again.',
          emailSend: 'Could not send the confirmation email. Please try again shortly.',
          email: 'Enter a valid email address.',
          consent: 'Newsletter subscription requires consent.',
        },
      };
      var msg = messages[locale] || messages.fi;

      function showMessage(text, isError) {
        if (!messageEl) return;
        messageEl.textContent = text;
        messageEl.classList.remove('hidden', 'text-cyan-400', 'text-red-400');
        messageEl.classList.add(isError ? 'text-red-400' : 'text-cyan-400');
      }

      var emailInput = form.querySelector('input[name="email"]');
      var consentInput = form.querySelector('input[name="consentMarketing"]');
      var langSelect = form.querySelector('select[name="preferredLanguage"]');
      var honeypot = form.querySelector('input[name="website"]');
      var email = emailInput && 'value' in emailInput ? String(emailInput.value).trim() : '';

      if (!email || email.indexOf('@') < 1) {
        showMessage(msg.email, true);
        return;
      }
      if (!consentInput || !('checked' in consentInput) || !consentInput.checked) {
        showMessage(msg.consent, true);
        return;
      }

      if (submitBtn && 'disabled' in submitBtn) submitBtn.disabled = true;

      try {
        var response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: email,
            locale: locale,
            preferredLanguage: langSelect && 'value' in langSelect ? langSelect.value : locale,
            consentMarketing: true,
            sourceUrl: form.getAttribute('data-source-url') || window.location.pathname,
            honeypot: honeypot && 'value' in honeypot ? honeypot.value : '',
          }),
        });

        var data = await response.json();
        if (!response.ok) {
          var code = data && data.error ? data.error : 'generic';
          if (code === 'invalid_email') showMessage(msg.email, true);
          else if (code === 'consent_required') showMessage(msg.consent, true);
          else if (code === 'email_send_failed') showMessage(msg.emailSend, true);
          else showMessage(msg.generic, true);
          return;
        }

        showMessage(msg.success, false);
        form.reset();
      } catch (err) {
        showMessage(msg.generic, true);
      } finally {
        if (submitBtn && 'disabled' in submitBtn) submitBtn.disabled = false;
      }
    });
  });
</script>
