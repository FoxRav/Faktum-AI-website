---
interface Metric {
  label: string;
  value: string;
  description?: string;
}

interface Props {
  items: Metric[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <div class="my-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((item) => (
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-4">
        <p class="font-serif text-2xl font-bold text-cyan-400">{item.value}</p>
        <p class="mt-1 font-sans text-sm font-medium text-[var(--color-text)]">{item.label}</p>
        {item.description && (
          <p class="mt-1 text-xs text-[var(--color-text-muted)]">{item.description}</p>
        )}
      </div>
    ))}
  </div>
)}
