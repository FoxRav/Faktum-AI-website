---
interface DataPoint {
  label: string;
  value: number;
}

interface Props {
  data: DataPoint[];
  title?: string;
  unit?: string;
  scaleMax?: number;
  compact?: boolean;
}

const PLOT_HEIGHT_PX = 120;
const LABEL_ROW_PX = 28;

const { data, title, unit = '', scaleMax: scaleMaxProp, compact = true } = Astro.props;

function formatValue(value: number): string {
  return value.toLocaleString('fi-FI', { maximumFractionDigits: 2 });
}

function niceScaleMax(maxVal: number): number {
  if (maxVal <= 0) return 10;
  if (maxVal < 10) return Math.ceil(maxVal * 1.25 * 10) / 10;
  if (maxVal <= 40) return 40;
  if (maxVal <= 100) return 100;
  if (maxVal <= 250) return 200;
  if (maxVal <= 500) return 500;
  if (maxVal <= 1000) return 1000;
  return Math.ceil(maxVal / 500) * 500;
}

function buildTicks(scaleMax: number): number[] {
  const tickCount = 4;
  const step = scaleMax / tickCount;
  const ticks: number[] = [];
  for (let index = tickCount; index >= 0; index -= 1) {
    const tick = step * index;
    ticks.push(Number.isInteger(tick) ? tick : Math.round(tick * 10) / 10);
  }
  return ticks;
}

const dataMax = Math.max(...data.map((point) => point.value), 1);
const scaleMax = scaleMaxProp ?? niceScaleMax(dataMax);
const ticks = buildTicks(scaleMax);
const wideLayout = data.length >= 3;
const peakIndex = data.reduce(
  (best, point, index) => (point.value > data[best].value ? index : best),
  0,
);
---

{data.length > 0 && (
  <figure class:list={['not-prose chart-figure', wideLayout && 'chart-figure--wide', !compact && 'max-w-lg']}>
    {title && <figcaption class="chart-figure__title">{title}</figcaption>}
    {unit && <p class="chart-figure__unit">{unit}</p>}
    <div
      class="chart-panel"
      role="img"
      aria-label={title ? `${title}${unit ? ` (${unit})` : ''}` : 'Pylväskaavio'}
      style={`--chart-plot-h: ${PLOT_HEIGHT_PX}px; --chart-label-h: ${LABEL_ROW_PX}px`}
    >
      <div class="chart-body">
        <div class="chart-y-axis" aria-hidden="true">
          {ticks.map((tick) => (
            <span class="chart-y-axis__tick">{formatValue(tick)}</span>
          ))}
        </div>
        <div class="chart-plot">
          <div class="chart-grid" aria-hidden="true">
            {ticks.slice(0, -1).map(() => (
              <div class="chart-grid__line" />
            ))}
          </div>
          <div class="chart-columns">
            {data.map((point, index) => {
              const barHeightPx = Math.max((point.value / scaleMax) * PLOT_HEIGHT_PX, 8);
              const isPeak = index === peakIndex;
              return (
                <div class="chart-column">
                  <div class="chart-bar-stack">
                    <span class:list={['chart-value', isPeak && 'chart-value--peak']}>
                      {formatValue(point.value)}
                    </span>
                    <div
                      class:list={['chart-bar', isPeak && 'chart-bar--peak']}
                      style={`height: ${barHeightPx}px`}
                    />
                  </div>
                  <span class="chart-label">{point.label}</span>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </figure>
)}
