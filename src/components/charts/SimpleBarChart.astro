---
interface DataPoint {
  label: string;
  value: number;
}

interface Props {
  data: DataPoint[];
  title?: string;
}

const { data, title } = Astro.props;
const max = Math.max(...data.map((d) => d.value), 1);
const barHeight = 160;
const topPadding = 28;
const bottomPadding = 36;
const chartWidth = data.length * 80;
const totalHeight = topPadding + barHeight + bottomPadding;
---

{data.length > 0 && (
  <figure class="my-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
    {title && <figcaption class="mb-4 font-sans text-sm font-semibold text-[var(--color-text)]">{title}</figcaption>}
    <svg
      viewBox={`0 0 ${chartWidth} ${totalHeight}`}
      class="w-full max-w-lg text-cyan-400"
      role="img"
      aria-label={title ?? 'Pylväskaavio'}
    >
      {data.map((point, i) => {
        const h = (point.value / max) * barHeight;
        const x = i * 80 + 20;
        const barTop = topPadding + barHeight - h;
        const labelY = barTop - 8;
        const axisLabelY = topPadding + barHeight + 22;
        return (
          <g>
            <rect
              x={x}
              y={barTop}
              width="40"
              height={h}
              rx="4"
              fill="currentColor"
              opacity="0.85"
            />
            <text
              x={x + 20}
              y={axisLabelY}
              text-anchor="middle"
              class="fill-[var(--color-text-muted)] text-[10px]"
              font-family="system-ui, sans-serif"
            >
              {point.label}
            </text>
            <text
              x={x + 20}
              y={labelY}
              text-anchor="middle"
              dominant-baseline="auto"
              class="fill-[var(--color-text-dim)] text-[11px] font-semibold"
              font-family="system-ui, sans-serif"
            >
              {point.value}
            </text>
          </g>
        );
      })}
    </svg>
  </figure>
)}
