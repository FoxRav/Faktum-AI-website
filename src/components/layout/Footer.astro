---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--color-border)] py-12">
  <div class="container-site grid gap-8 md:grid-cols-3">
    <div>
      <p class="font-semibold text-[var(--color-text)]">
        <span class="text-cyan-400">Faktum</span> AI
      </p>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">
        Suomenkielistä tekoälyuutisointia, analyysia ja käytännön AI-rakentamista.
      </p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
        Sisältö
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/uutiset/" class="text-[var(--color-text-dim)] hover:text-cyan-400">Uutiset</a></li>
        <li><a href="/analyysit/" class="text-[var(--color-text-dim)] hover:text-cyan-400">Analyysit</a></li>
        <li><a href="/haastattelut/" class="text-[var(--color-text-dim)] hover:text-cyan-400">Haastattelut</a></li>
        <li><a href="/tyokalut/" class="text-[var(--color-text-dim)] hover:text-cyan-400">Työkalut</a></li>
      </ul>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
        Palvelut
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/rss.xml" class="text-[var(--color-text-dim)] hover:text-cyan-400">RSS-syöte</a></li>
        <li><a href="/tietoa/" class="text-[var(--color-text-dim)] hover:text-cyan-400">Tietoa Faktum AI:sta</a></li>
      </ul>
    </div>
  </div>
  <div class="container-site mt-10 border-t border-[var(--color-border)] pt-6 text-center text-xs text-[var(--color-text-muted)]">
    © {year} Faktum AI · www.faktum-ai.com
  </div>
</footer>
