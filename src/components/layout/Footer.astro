---
import { getLocaleFromPath, categoryPath } from '../../i18n/paths';
import { t } from '../../i18n/ui';

const year = new Date().getFullYear();
const locale = getLocaleFromPath(Astro.url.pathname);
---

<footer class="mt-20 border-t border-[var(--color-border)] py-12">
  <div class="container-site grid gap-8 md:grid-cols-3">
    <div>
      <p class="font-semibold text-[var(--color-text)]">
        <span class="text-cyan-400">Faktum</span> AI
      </p>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">
        {t(locale, 'footerTagline')}
      </p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
        {t(locale, 'footerContent')}
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a href={categoryPath(locale, 'news')} class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'navNews')}
          </a>
        </li>
        <li>
          <a href={categoryPath(locale, 'analysis')} class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'navAnalysis')}
          </a>
        </li>
        <li>
          <a href={categoryPath(locale, 'interviews')} class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'navInterviews')}
          </a>
        </li>
        <li>
          <a href={categoryPath(locale, 'tools')} class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'navTools')}
          </a>
        </li>
        <li>
          <a href={categoryPath(locale, 'topics')} class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'navTopics')}
          </a>
        </li>
      </ul>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
        {t(locale, 'footerServices')}
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a href="/rss.xml" class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'footerRss')}
          </a>
        </li>
        <li>
          <a href="/llms.txt" class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'footerLlm')}
          </a>
        </li>
        <li>
          <a href={categoryPath(locale, 'about')} class="text-[var(--color-text-dim)] hover:text-cyan-400">
            {t(locale, 'navAbout')}
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="container-site mt-10 border-t border-[var(--color-border)] pt-6 text-center text-xs text-[var(--color-text-muted)]">
    © {year} Faktum AI · www.faktum-ai.com
  </div>
</footer>
