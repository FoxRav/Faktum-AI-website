---
import MobileMenu from './MobileMenu.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocaleFromPath } from '../../i18n/paths';
import { getNavItems } from '../../i18n/ui';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const nav = getNavItems(locale);
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur-md">
  <div class="container-site flex h-16 items-center justify-between gap-4">
    <a
      href={locale === 'fi' ? '/' : '/en/'}
      class="flex items-center gap-2 font-semibold tracking-tight text-[var(--color-text)]"
    >
      <span class="text-cyan-400">Faktum</span>
      <span class="text-[var(--color-text-dim)]">AI</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {nav.map((item) => {
        const active =
          item.href === '/' || item.href === '/en/'
            ? currentPath === item.href
            : currentPath.startsWith(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-2 text-sm transition',
              active
                ? 'bg-cyan-500/10 text-cyan-300'
                : 'text-[var(--color-text-dim)] hover:text-[var(--color-text)]',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <LanguageSwitcher />
      <MobileMenu nav={nav} currentPath={currentPath} />
    </div>
  </div>
</header>
