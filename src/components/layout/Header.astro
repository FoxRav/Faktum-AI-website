---
import MobileMenu from './MobileMenu.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocaleFromPath } from '../../i18n/paths';
import { getNavItems } from '../../i18n/ui';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const nav = getNavItems(locale);

function isNavActive(href: string): boolean {
  return currentPath === href || (href !== '/' && href !== '/en/' && currentPath.startsWith(href));
}
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur-md">
  <div class="container-site flex h-16 items-center gap-2 sm:gap-3">
    <a
      href={locale === 'fi' ? '/' : '/en/'}
      class="flex shrink-0 items-center gap-2 font-semibold tracking-tight text-[var(--color-text)]"
    >
      <span class="text-cyan-400">Faktum</span>
      <span class="text-[var(--color-text-dim)]">AI</span>
    </a>

    <nav
      class="hidden min-w-0 flex-1 items-center gap-0.5 overflow-x-auto md:flex [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      aria-label="Main navigation"
    >
      {nav.map((item) => {
        const active = isNavActive(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'shrink-0 rounded-md px-2 py-2 text-xs font-medium transition sm:px-2.5 sm:text-sm lg:px-3',
              item.highlight
                ? active
                  ? 'bg-cyan-500/20 text-cyan-300'
                  : 'bg-cyan-500/10 text-cyan-400 hover:bg-cyan-500/15 hover:text-cyan-300'
                : active
                  ? 'bg-cyan-500/10 text-cyan-300'
                  : 'text-[var(--color-text-dim)] hover:text-[var(--color-text)]',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <LanguageSwitcher />
      <MobileMenu nav={nav} currentPath={currentPath} />
    </div>
  </div>
</header>
