---
import MobileMenu from './MobileMenu.astro';

const nav = [
  { href: '/', label: 'Etusivu' },
  { href: '/uutiset/', label: 'Uutiset' },
  { href: '/analyysit/', label: 'Analyysit' },
  { href: '/tyokalut/', label: 'Työkalut' },
  { href: '/haastattelut/', label: 'Haastattelut' },
  { href: '/projektit/', label: 'Projektit' },
  { href: '/tietoa/', label: 'Tietoa' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur-md">
  <div class="container-site flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-[var(--color-text)]">
      <span class="text-cyan-400">Faktum</span>
      <span class="text-[var(--color-text-dim)]">AI</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Päänavigaatio">
      {nav.map((item) => {
        const active =
          item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-2 text-sm transition',
              active
                ? 'bg-cyan-500/10 text-cyan-300'
                : 'text-[var(--color-text-dim)] hover:text-[var(--color-text)]',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <MobileMenu nav={nav} currentPath={currentPath} />
  </div>
</header>
