---
const landingImage = '/images/brand/landing-hero.webp';
const landingAlt =
  'Faktum AI — suomenkielinen tekoälyuutisointi, analyysi ja käytännön AI-rakentaminen';
---

<section class="container-site py-12 sm:py-16 lg:py-20">
  <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">
        Suomenkielinen AI-media
      </p>
      <h1 class="mt-4 font-sans text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl lg:text-[3.25rem]">
        Tekoälyuutisointia, <span class="text-cyan-400">analyysia</span> ja käytännön rakentamista
      </h1>
      <p class="mt-6 text-lg text-[var(--color-text-dim)]">
        Faktum AI purkaa kansainväliset AI-kehitykset, raportit ja haastattelut suomalaiselle
        lukijalle — lähteitä kunnioittaen, hypeä välttäen.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/uutiset/" class="btn-primary">Uusimmat uutiset</a>
        <a href="/analyysit/" class="btn-ghost">Analyysit</a>
      </div>
    </div>

    <figure class="relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] shadow-[0_0_60px_rgba(34,211,238,0.08)]">
      <img
        src={landingImage}
        alt={landingAlt}
        class="aspect-[16/10] w-full object-cover"
        width="1200"
        height="750"
        fetchpriority="high"
      />
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/40 via-transparent to-transparent lg:bg-gradient-to-l lg:from-[var(--color-bg)]/30"
        aria-hidden="true"
      />
    </figure>
  </div>
</section>
