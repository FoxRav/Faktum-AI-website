---
interface Tab {
  href: string;
  label: string;
}

interface Props {
  tabs: Tab[];
  activeHref: string;
}

const { tabs, activeHref } = Astro.props;
---

<nav class="container-site border-b border-[var(--color-border)]" aria-label="Sisältövälilehdet">
  <ul class="flex gap-1 overflow-x-auto pb-px [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
    {tabs.map((tab) => {
      const active = tab.href === activeHref;
      return (
        <li>
          <a
            href={tab.href}
            class:list={[
              'block whitespace-nowrap border-b-2 px-4 py-3 text-sm font-medium transition',
              active
                ? 'border-cyan-400 text-cyan-300'
                : 'border-transparent text-[var(--color-text-dim)] hover:text-[var(--color-text)]',
            ]}
          >
            {tab.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
