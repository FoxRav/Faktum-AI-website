---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/ui';

interface Source {
  title: string;
  url?: string;
  publisher?: string;
  date?: string;
}

interface Props {
  sources: Source[];
  locale?: Locale;
}

const { sources, locale = 'fi' } = Astro.props;
---

{sources.length > 0 && (
  <section class="mt-12 border-t border-[var(--color-border)] pt-8">
    <h2 class="font-sans text-xl font-bold text-[var(--color-text)]">{t(locale, 'sourcesTitle')}</h2>
    <ol class="mt-4 space-y-3">
      {sources.map((source, i) => (
        <li class="text-sm text-[var(--color-text-dim)]">
          <span class="text-[var(--color-text-muted)]">{i + 1}. </span>
          {source.url ? (
            <a href={source.url} rel="noopener noreferrer" target="_blank" class="text-cyan-400 hover:underline">
              {source.title}
            </a>
          ) : (
            <span>{source.title}</span>
          )}
          {(source.publisher || source.date) && (
            <span class="text-[var(--color-text-muted)]">
              {' '}
              — {[source.publisher, source.date].filter(Boolean).join(', ')}
            </span>
          )}
        </li>
      ))}
    </ol>
  </section>
)}
