---
import ListingLayout from '../../layouts/ListingLayout.astro';
import ArticleFeed from '../../components/sections/ArticleFeed.astro';
import { getArticlesByCollection } from '../../utils/content';

const articles = await getArticlesByCollection('analysis');
---

<ListingLayout
  title="Analyysit"
  description="Syvällisiä analyyseja AI-markkinoista, infrastruktuurista ja liiketoimintamalleista."
  path="/analyysit/"
  activeTab="/analyysit/"
>
  <ArticleFeed articles={articles} title="" emptyMessage="Ei analyyseja vielä julkaistu." />
</ListingLayout>
