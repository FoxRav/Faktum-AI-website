import UnsubscribeForm from '../../../components/forms/UnsubscribeForm.astro';
import { subscribePath } from '../../../i18n/paths';

const locale = 'en' as const;
---

<BaseLayout
  title="Unsubscribe"
  description="Unsubscribe from the Faktum AI newsletter."
  path={subscribePath(locale, 'unsubscribe')}
>
  <UnsubscribeForm locale={locale} />
</BaseLayout>
