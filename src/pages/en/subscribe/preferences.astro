---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PreferenceForm from '../../../components/forms/PreferenceForm.astro';
import { subscribePath } from '../../../i18n/paths';

const locale = 'en' as const;
const token = Astro.url.searchParams.get('token') ?? '';
---

<BaseLayout
  title="Subscriber profile"
  description="Manage your Faktum AI newsletter role and interests."
  path={subscribePath(locale, 'preferences')}
>
  <PreferenceForm locale={locale} token={token} />
</BaseLayout>
