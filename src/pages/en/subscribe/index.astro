---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../../components/forms/NewsletterSignup.astro';
import { subscribePath } from '../../../i18n/paths';
import { t } from '../../../i18n/ui';

const locale = 'en' as const;
---

<BaseLayout
  title={t(locale, 'subscribeTitle')}
  description={t(locale, 'subscribeLead')}
  path={subscribePath(locale)}
>
  <section class="container-site py-12 lg:py-16">
    <div class="mx-auto max-w-2xl">
      <h1 class="font-sans text-3xl font-bold sm:text-4xl">{t(locale, 'subscribeTitle')}</h1>
      <p class="mt-4 text-[var(--color-text-dim)]">{t(locale, 'subscribeLead')}</p>
      <div class="mt-8">
        <NewsletterSignup locale={locale} variant="full" sourceUrl={subscribePath(locale)} />
      </div>
    </div>
  </section>
</BaseLayout>
