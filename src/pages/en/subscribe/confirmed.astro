---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { subscribePath } from '../../../i18n/paths';
import { t } from '../../../i18n/ui';

const locale = 'en' as const;
---

<BaseLayout
  title="Subscription confirmed"
  description="Your Faktum AI newsletter subscription is confirmed."
  path={subscribePath(locale, 'confirmed')}
>
  <section class="container-site py-16 text-center">
    <h1 class="font-sans text-3xl font-bold">{t(locale, 'subscribeConfirmed')}</h1>
    <p class="mt-4 text-[var(--color-text-dim)]">Check your email to complete your profile.</p>
  </section>
</BaseLayout>
