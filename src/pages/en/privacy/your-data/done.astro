---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { t } from '../../../../i18n/ui';

const locale = 'en' as const;
const result = Astro.url.searchParams.get('result');
const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Request processed" description="Data request processed." path="/en/privacy/your-data/done/">
  <section class="container-site py-16 text-center">
    <h1 class="font-sans text-3xl font-bold">Request processed</h1>
    {error && <p class="mt-4 text-red-400">{t(locale, 'subscribeInvalidToken')}</p>}
    {result === 'deleted' && <p class="mt-4 text-[var(--color-text-dim)]">Your data has been deleted.</p>}
    {result === 'export_sent' && <p class="mt-4 text-[var(--color-text-dim)]">Export completed.</p>}
  </section>
</BaseLayout>
