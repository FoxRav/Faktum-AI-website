---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getAllArticles, type ArticleEntry } from '../../../utils/content';

export async function getStaticPaths() {
  const entries = await getCollection('interviewsEn', ({ data }) => data.status === 'published');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const article: ArticleEntry = { ...entry, collection: 'interviews', locale: 'en' };
const allArticles = await getAllArticles('en');
---

<ArticleLayout article={article} allArticles={allArticles}>
  <Content />
</ArticleLayout>
