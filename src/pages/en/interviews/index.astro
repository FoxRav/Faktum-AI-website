---
import ListingLayout from '../../../layouts/ListingLayout.astro';
import ArticleFeed from '../../../components/sections/ArticleFeed.astro';
import { getArticlesByCollection } from '../../../utils/content';
import { categoryPath } from '../../../i18n/paths';
import { t } from '../../../i18n/ui';

const locale = 'en' as const;
const articles = await getArticlesByCollection('interviews', locale);
---

<ListingLayout
  title={t(locale, 'navInterviews')}
  description={t(locale, 'listingInterviews')}
  path="/en/interviews/"
  activeTab={categoryPath(locale, 'interviews')}
  locale={locale}
>
  <ArticleFeed articles={articles} title="" emptyMessage={t(locale, 'emptyArticles')} />
</ListingLayout>
