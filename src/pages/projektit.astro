---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Projektit"
  description="Faktum AI -projektit ja Cursor-first-kehitys."
  path="/projektit/"
>
  <section class="container-site py-12 lg:py-16">
    <h1 class="font-sans text-3xl font-bold sm:text-4xl">Projektit</h1>
    <p class="mt-4 max-w-2xl text-[var(--color-text-dim)]">
      Tähän osioon kootaan myöhemmin Faktum AI:n käytännön projektit, Cursor-first-kehitysesimerkit
      ja avoimen lähdekoodin työt. Osio on valmistelussa.
    </p>
  </section>
</BaseLayout>
